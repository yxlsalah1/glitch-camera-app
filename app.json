{
  "expo": {
    "name": "GlitchCamera",
    "slug": "glitch-camera-app",
    "version": "0.1.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTabletOnly": false,
      "bundleIdentifier": "com.yxlsalah.glitchcamera",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to apply real-time glitch effects",
        "NSPhotoLibraryUsageDescription": "We need to save glitched videos to your library",
        "NSPhotoLibraryAddUsageDescription": "We need to save glitched videos to your library"
      }
    },
    "android": {
      "package": "com.yxlsalah.glitchcamera",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ]
    ]
  }
}
